  "components": {
    "schemas": {
      "AskQuestionRequest": {
        "required": [
          "question"
        ],
        "type": "object",
        "properties": {
          "question": {
            "type": "string"
          },
          "sourceId": {
            "type": [
              "null",
              "string"
            ]
          },
          "maxCitations": {
            "maximum": 10,
            "minimum": 1,
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "AskQuestionResponse": {
        "type": "object",
        "properties": {
          "answer": {
            "type": "string"
          },
          "grounded": {
            "type": "boolean"
          },
          "insufficientContext": {
            "type": "boolean"
          },
          "confidence": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "citations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CitationResponse"
            }
          }
        }
      },
      "CitationResponse": {
        "type": "object",
        "properties": {
          "chunkId": {
            "type": "string"
          },
          "sourceId": {
            "type": "string"
          },
          "sourceName": {
            "type": "string"
          },
          "sourceLocation": {
            "type": [
              "null",
              "string"
            ]
          },
          "snippet": {
            "type": "string"
          },
          "score": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "DiagnosticsSummaryResponse": {
        "type": "object",
        "properties": {
          "totalIngestions": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "totalRetrievedQueries": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "totalChatRequests": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "totalBackgroundJobsProcessed": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "averageIngestionDurationMs": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "averageRetrievalDurationMs": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "averageChatDurationMs": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "averageBackgroundJobDurationMs": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "IFormFile": {
        "type": "string",
        "format": "binary"
      },
      "IFormFileCollection": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/IFormFile"
        }
      },
      "IngestionJobAcceptedResponse": {
        "type": "object",
        "properties": {
          "jobId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "queuedAtUtc": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "IngestionJobStatusResponse": {
        "type": "object",
        "properties": {
          "jobId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "sourceType": {
            "type": "string"
          },
          "queuedAtUtc": {
            "type": "string",
            "format": "date-time"
          },
          "startedAtUtc": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "completedAtUtc": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "error": {
            "type": [
              "null",
              "string"
            ]
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IngestionResponse"
            }
          }
        }
      },
      "IngestionResponse": {
        "type": "object",
        "properties": {
          "documentId": {
            "type": "string"
          },
          "sourceId": {
            "type": "string"
          },
          "sourceName": {
            "type": "string"
          },
          "chunkCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "ingestedAtUtc": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "IngestTextRequest": {
        "required": [
          "content",
          "sourceName"
        ],
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          },
          "sourceName": {
            "type": "string"
          },
          "sourceId": {
            "type": [
              "null",
              "string"
            ]
          },
          "sourceLocation": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "IngestWebPageRequest": {
        "required": [
          "url"
        ],
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "sourceId": {
            "type": [
              "null",
              "string"
            ]
          },
          "sourceName": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    }
  },
